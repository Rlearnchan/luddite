{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnnyRunManifest",
  "type": "object",
  "required": [
    "run_id",
    "status",
    "input_bundle_path",
    "output_storyline_path",
    "eval_report_path",
    "model_source",
    "schema_valid",
    "hygiene_passed",
    "output_contract_version",
    "prompt_version",
    "validator_version",
    "schema_version",
    "input_bundle_sha256",
    "evidence_pack_sha256",
    "output_storyline_sha256",
    "hygiene_sidecar_sha256",
    "prompt_file_sha256",
    "created_at",
    "notes"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "pending_manual_output"
      ]
    },
    "input_bundle_path": {
      "type": "string"
    },
    "evidence_pack_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "output_storyline_path": {
      "type": "string"
    },
    "eval_report_path": {
      "type": "string"
    },
    "model_source": {
      "type": "string",
      "enum": [
        "manual_gpt_pro",
        "openai_api",
        "api_future",
        "fixture"
      ]
    },
    "raw_model_output_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "parsed_storyline_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "api_experiment_dir": {
      "type": [
        "string",
        "null"
      ]
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failureMode"
      },
      "default": []
    },
    "ready_for_api_experiment_prep": {
      "type": "boolean"
    },
    "ready_for_api_experiment": {
      "type": "boolean"
    },
    "ready_for_production_agent": {
      "type": "boolean"
    },
    "schema_valid": {
      "type": "boolean"
    },
    "hygiene_passed": {
      "type": "boolean"
    },
    "output_contract_version": {
      "type": "string"
    },
    "prompt_version": {
      "type": "string"
    },
    "validator_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "input_bundle_sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_pack_sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "output_storyline_sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "hygiene_sidecar_sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "prompt_file_sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "input_bundle_exists": {
      "type": "boolean"
    },
    "evidence_pack_exists": {
      "type": "boolean"
    },
    "output_storyline_exists": {
      "type": "boolean"
    },
    "hygiene_sidecar_exists": {
      "type": "boolean"
    },
    "prompt_file_exists": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "failureMode": {
      "type": "string",
      "enum": [
        "invalid_json",
        "schema_error",
        "missing_required_fields",
        "source_hallucination",
        "unsupported_claim",
        "do_not_claim_violation",
        "source_image_overlap",
        "counterpoint_missing",
        "needs_fact_check_removed_too_aggressively",
        "production_checklist_misused",
        "investment_advice_violation",
        "policy_promotion_violation",
        "korea_bridge_overreach",
        "key_beat_drift",
        "source_ref_role_mismatch",
        "required_before_broadcast_missing"
      ]
    }
  }
}
