{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnnyInputBundle",
  "type": "object",
  "required": [
    "bundle_id",
    "story_seed_id",
    "story_seed_title",
    "editorial_category",
    "seed_type",
    "readiness",
    "handoff_priority",
    "core_question",
    "why_story",
    "known_facts",
    "candidate_articles",
    "missing_evidence",
    "required_evidence",
    "nice_to_have_evidence",
    "fact_check_tasks",
    "official_source_tasks",
    "suggested_official_sources",
    "possible_story_angles",
    "suggested_story_structure",
    "opening_hook",
    "audience_question",
    "slide_count_target",
    "tone_notes",
    "must_include",
    "avoid",
    "risk_flags",
    "risk_level",
    "quality_flags",
    "do_not_claim",
    "needs_fact_check",
    "llm_enrichment_needed",
    "created_at"
  ],
  "properties": {
    "bundle_id": { "type": "string" },
    "story_seed_id": { "type": "string" },
    "story_seed_title": { "type": "string" },
    "editorial_category": { "type": "string" },
    "seed_type": { "type": "string" },
    "readiness": { "type": "string" },
    "handoff_priority": { "type": "string", "enum": ["high", "medium", "low"] },
    "core_question": { "type": "string" },
    "why_story": { "type": "string" },
    "known_facts": { "type": "array", "items": { "type": "string" } },
    "candidate_articles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "title",
          "url",
          "source",
          "source_id",
          "published_at",
          "summary",
          "risk_flags",
          "source_url_canonical",
          "duplicate_key",
          "why_interesting",
          "possible_expansions",
          "evidence_needed",
          "final_grade",
          "recommended_action",
          "editorial_category",
          "quality_flags"
        ],
        "properties": {
          "candidate_id": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": ["string", "null"] },
          "source": { "type": ["string", "null"] },
          "source_id": { "type": ["string", "null"] },
          "published_at": { "type": ["string", "null"] },
          "summary": { "type": ["string", "null"] },
          "risk_flags": { "type": "array", "items": { "type": "string" } },
          "source_url_canonical": { "type": ["string", "null"] },
          "duplicate_key": { "type": ["string", "null"] },
          "why_interesting": { "type": ["string", "null"] },
          "possible_expansions": { "type": "array", "items": { "type": "string" } },
          "evidence_needed": { "type": "array", "items": { "type": "string" } },
          "final_grade": { "type": ["string", "null"] },
          "recommended_action": { "type": ["string", "null"] },
          "editorial_category": { "type": ["string", "null"] },
          "quality_flags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "missing_evidence": { "type": "array", "items": { "type": "string" } },
    "required_evidence": { "type": "array", "items": { "type": "string" } },
    "nice_to_have_evidence": { "type": "array", "items": { "type": "string" } },
    "fact_check_tasks": { "type": "array", "items": { "type": "string" } },
    "official_source_tasks": { "type": "array", "items": { "type": "string" } },
    "suggested_official_sources": { "type": "array", "items": { "type": "string" } },
    "possible_story_angles": { "type": "array", "items": { "type": "string" } },
    "suggested_story_structure": { "type": "array", "items": { "type": "string" } },
    "opening_hook": { "type": "string" },
    "audience_question": { "type": "string" },
    "slide_count_target": { "type": "string" },
    "visual_planning_hint": {
      "type": "object",
      "required": [
        "slideability_score",
        "visualizability",
        "first_slide_idea",
        "likely_proof_object_types",
        "visual_risks",
        "reason",
        "planning_note"
      ],
      "properties": {
        "slideability_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "visualizability": { "type": "string", "enum": ["low", "medium", "high"] },
        "first_slide_idea": { "type": "string" },
        "likely_proof_object_types": {
          "type": "array",
          "items": { "type": "string", "enum": ["diagram", "chart", "source_card"] }
        },
        "visual_risks": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "too_abstract",
              "single_source",
              "needs_official_data",
              "policy_claim_risk",
              "market_claim_risk",
              "no_clear_visual"
            ]
          }
        },
        "reason": { "type": "string" },
        "planning_note": { "type": "string" }
      }
    },
    "tone_notes": { "type": "array", "items": { "type": "string" } },
    "must_include": { "type": "array", "items": { "type": "string" } },
    "avoid": { "type": "array", "items": { "type": "string" } },
    "risk_flags": { "type": "array", "items": { "type": "string" } },
    "quality_flags": { "type": "array", "items": { "type": "string" } },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "do_not_claim": { "type": "array", "items": { "type": "string" } },
    "needs_fact_check": { "type": "boolean" },
    "llm_enrichment_needed": { "type": "boolean" },
    "created_at": { "type": "string" }
  }
}
