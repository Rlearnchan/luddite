{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JibiCandidate",
  "type": "object",
  "required": [
    "candidate_id",
    "title",
    "seed_url",
    "source",
    "seed_type",
    "summary",
    "why_interesting",
    "scores",
    "risk_flags",
    "status"
  ],
  "properties": {
    "candidate_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "seed_url": {
      "type": "string"
    },
    "source_url_canonical": {
      "type": "string"
    },
    "duplicate_key": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "published_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "collected_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "first_seen_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_seen_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_count": {
      "type": "integer",
      "minimum": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "normal",
        "bdc"
      ]
    },
    "seed_type": {
      "type": "string",
      "enum": [
        "absurd_foreign",
        "life_change",
        "cost_asymmetry",
        "policy_market_shock",
        "political_fracture",
        "geopolitical_prequel",
        "industry_disruption",
        "meme_bridge",
        "science_technology",
        "labor_society",
        "bdc_candidate",
        "other"
      ]
    },
    "summary": {
      "type": "string"
    },
    "why_interesting": {
      "type": "string"
    },
    "possible_expansions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "korea_bridge": {
      "type": [
        "string",
        "null"
      ]
    },
    "punchline_candidate": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_needed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/riskFlag"
      }
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failureMode"
      }
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "recommended_action": {
      "type": "string",
      "enum": [
        "send_to_anny",
        "gather_more_evidence",
        "editorial_review",
        "keep_for_later",
        "reject",
        "blocked_policy"
      ]
    },
    "past_video_matches": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "past_performance_proxy": {
      "type": [
        "object",
        "null"
      ]
    },
    "recent_cooldown_risk": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "collected",
        "scored",
        "shortlisted",
        "sent_to_anny",
        "archived",
        "rejected",
        "candidate"
      ]
    }
  },
  "$defs": {
    "riskFlag": {
      "type": "string",
      "enum": [
        "political_sensitivity",
        "religion_ethnicity_sensitivity",
        "minority_group_sensitivity",
        "corporate_promo_risk",
        "single_source_dependency",
        "copyright_image_risk",
        "subscription_source_only",
        "medical_claim_risk",
        "investment_advice_risk",
        "crime_or_drug_sensitivity",
        "live_news_volatility",
        "bdc_conflict",
        "brand_safety_risk",
        "advertiser_claim_risk",
        "legal_review_needed",
        "overly_promotional",
        "needs_human_review"
      ]
    },
    "failureMode": {
      "type": "string",
      "enum": [
        "sub_item_only",
        "too_obvious_pattern",
        "single_company_frame",
        "single_stock_investment_frame",
        "weak_structural_expansion",
        "thin_evidence",
        "sensitive_high_low_gain",
        "live_news_volatility",
        "political_direct_eval",
        "recent_cooldown",
        "copyright_heavy"
      ]
    },
    "url": {
      "type": "string",
      "format": "uri"
    }
  }
}
